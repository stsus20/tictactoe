{
  "expo": {
    "name": "Tic Tac Toe",
    "slug": "tictactoe",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.tictactoe"
    },
    "android": {
      "package": "com.yourcompany.tictactoe"
    },
    "extra": {
      "router": {
        "origin": false
      }
    },
    "plugins": ["expo-router"]
  }
}